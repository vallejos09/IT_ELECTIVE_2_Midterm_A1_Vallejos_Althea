@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome</h1>
</div>

<section id="home" class="text-center my-5">
    <div class="container text-center">
        <img src="~/images/profile.jpg" 
            class="rounded-circle img-fluid mb-3" 
            width="150" 
            alt="Profile Photo" />
        <h1 class="display-4">Althea Vallejos</h1>
        <h4 class="text-muted">BSIT Student | Aspiring Developer</h4>
        <p class="lead">
            I am Althea, a motivated student who enjoys learning new things and exploring creative ideas. I value collaboration, growth, and finding ways to make a positive impact in whatever I do.
        </p>
        <a asp-controller="Home" asp-action="Projects" class="btn btn-primary me-2">View Projects</a>
        <a asp-controller="Home" asp-action="Contacts" class="btn btn-outline-secondary">Contact Me</a>
    </div>
</section>

